{
  "name": "web",
  "private": true,
  "version": "0.7.21",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:vapid": "node -e \"const {webcrypto}=require('crypto');(async()=>{const k=await webcrypto.subtle.generateKey({name:'ECDH',namedCurve:'P-256'},true,['deriveKey']);const pub=Buffer.from(await webcrypto.subtle.exportKey('raw',k.publicKey)).toString('base64url');const jwk=await webcrypto.subtle.exportKey('jwk',k.privateKey);console.log('VITE_VAPID_PUBLIC_KEY='+pub);console.log('VAPID_PUBLIC_KEY='+pub);console.log('VAPID_PRIVATE_KEY='+jwk.d);console.log('VAPID_SUBJECT=mailto:admin@example.com');})();\""
  },
