# Скопируйте в .env.local и подставьте значения из Supabase → Settings → API
# Задокументированный prod-проект: https://ntpkveicqetjjvlnfrwc.supabase.co (см. web/README.md → «Проект Supabase»)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Web Push (публичный ключ VAPID, Base64 URL — пара к приватному ключу в секретах Edge Function)
VITE_VAPID_PUBLIC_KEY=

# Фаза 7: юридика и обратная связь (опционально; без URL — встроенные страницы-заглушки /legal/*)
# VITE_LEGAL_PRIVACY_URL=
# VITE_LEGAL_TERMS_URL=
# VITE_LEGAL_PERSONAL_DATA_URL=
# VITE_FEEDBACK_URL=  # optional; default: GitHub Issues (Chuchumbrik/planner)
